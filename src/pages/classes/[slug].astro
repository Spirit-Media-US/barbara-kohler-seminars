---
import Layout from '../../layouts/Layout.astro';
import { safeFetch } from '../../lib/sanity';

export async function getStaticPaths() {
  const courses = await safeFetch(
    `*[_type=="course"] | order(order asc){
      _id, title, level, status, body, price, priceNote, badge, ctaLabel, ctaHref, lessons
    }`,
    {},
    [],
  );
  return (courses || []).map((c) => ({
    params: { slug: c._id.replace(/^course-/, '') },
    props: { course: c },
  }));
}

const { course: c } = Astro.props;
const body = c.body || [];
const lessons = c.lessons || [];
// anchor links like "#subscribe" must be absolute from a sub-page
const ctaHref = c.ctaHref && c.ctaHref.startsWith('#') ? `/${c.ctaHref}` : c.ctaHref;
const isEnroll = c.status === 'available';
---
<Layout
  title={`${c.title} | Barbara Kohler Seminars`}
  description={body[0] || `${c.title} — a class in the Change Your Life Series from Barbara Kohler Seminars.`}
>
  <main id="top">
    <section class="course-hero" aria-labelledby="c-h">
      <div class="wrap">
        <span class="eyebrow">{c.level}</span>
        <h1 id="c-h">{c.title}</h1>
        {c.price && (
          <p class="price">{c.price} <span>{c.priceNote}</span></p>
        )}
        {c.badge && !c.price && <p class="badge">{c.badge}</p>}
        {ctaHref && (
          <div class="hero-ctas">
            <a class={`btn ${isEnroll ? 'btn-gold' : 'btn-outline-light'}`} href={ctaHref}>{c.ctaLabel}</a>
            <a class="btn btn-outline-light" href="/#classes">All classes</a>
          </div>
        )}
        <div class="scroll-rule center"><span></span></div>
      </div>
    </section>

    <section class="course-body">
      <div class="wrap">
        {body.map((p) => <p>{p}</p>)}

        {lessons.length > 0 && (
          <div class="lessons">
            <h2>What you&rsquo;ll learn</h2>
            <ol>
              {lessons.map((l) => (
                <li>
                  <span class="ln">{l.number}</span>
                  <h3>{l.title}</h3>
                  <p>{l.description}</p>
                </li>
              ))}
            </ol>
          </div>
        )}

        {isEnroll && ctaHref && (
          <div class="course-cta">
            <a class="btn btn-gold" href={ctaHref}>{c.ctaLabel} — {c.price}</a>
          </div>
        )}
      </div>
    </section>
  </main>
</Layout>

<style>
  .course-hero{background:radial-gradient(1100px 520px at 78% -10%, rgba(226,185,59,.14), transparent 60%),linear-gradient(165deg, var(--navy-ink) 0%, var(--sapphire-deep) 58%, var(--sapphire) 115%);color:#fff;padding:76px 0 72px;text-align:center}
  .course-hero .wrap{max-width:820px}
  .course-hero .eyebrow{display:block;margin-bottom:14px}
  .course-hero h1{font-size:40px;line-height:1.1;margin:0 0 14px}
  .price{font-size:22px;font-weight:700;color:var(--gold-bright)}
  .price span{display:block;font-size:13px;font-weight:400;color:#cfe0f2;letter-spacing:.02em}
  .badge{color:#cfe0f2;font-weight:600}
  .hero-ctas{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;margin:22px 0 8px}
  .course-body{padding:56px 0 88px;background:#fff}
  .course-body .wrap{max-width:760px}
  .course-body > .wrap > p{font-size:18px;line-height:1.75;color:#2a2a2a;margin:0 0 18px}
  .lessons{margin-top:38px}
  .lessons h2{font-size:26px;color:var(--navy-ink);margin:0 0 20px}
  .lessons ol{list-style:none;padding:0;margin:0;display:grid;gap:18px}
  .lessons li{border:1px solid var(--rule);border-left:4px solid var(--gold);border-radius:8px;padding:18px 20px}
  .lessons .ln{font-family:var(--sans);font-size:12px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:#9A7B14}
  .lessons h3{margin:4px 0 6px;font-size:18px;color:var(--navy-ink)}
  .lessons li p{margin:0;line-height:1.65;color:#3a3a3a}
  .course-cta{margin-top:40px;text-align:center}
</style>
