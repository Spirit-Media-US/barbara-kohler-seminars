---
import RelatedPosts from '../../components/RelatedPosts.astro';
import ShareBar from '../../components/ShareBar.astro';
import Layout from '../../layouts/Layout.astro';
import { sanityClient, urlFor } from '../../lib/sanity';

export async function getStaticPaths() {
  const posts = await sanityClient.fetch(
    `*[_type == "blogPost" && defined(slug.current)] { "slug": slug.current }`,
  );
  return (posts || [])
    .filter((p: any) => typeof p?.slug === 'string' && p.slug.length > 0)
    .map((p: any) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const post = await sanityClient.fetch(`*[_type == "blogPost" && slug.current == $slug][0]`, { slug });
if (!post || !post.slug?.current) return Astro.redirect('/blog');

function escapeHtml(s: string): string {
  return String(s)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}
function sanitizeUrl(url: string): string {
  const t = String(url).trim();
  return /^(https?:|mailto:|tel:|\/|#)/i.test(t) ? t : '#';
}
function renderPortableText(blocks: any[]): string {
  if (!Array.isArray(blocks)) return '';
  const renderChildren = (children: any[]): string =>
    children
      .map((child: any) => {
        if (!child) return '';
        let text = escapeHtml(child.text || '');
        const marks = Array.isArray(child.marks) ? child.marks : [];
        if (marks.includes('strong')) text = `<strong>${text}</strong>`;
        if (marks.includes('em')) text = `<em>${text}</em>`;
        const link = marks.find((m: any) => m && typeof m === 'object' && m._type === 'link');
        if (link?.href) {
          const href = escapeHtml(sanitizeUrl(link.href));
          text = `<a href="${href}" target="_blank" rel="noopener noreferrer">${text}</a>`;
        }
        return text;
      })
      .join('');

  const out: string[] = [];
  let buf: string[] = [];
  let listType: string | null = null;
  const flush = () => {
    if (!buf.length) return;
    const tag = listType === 'number' ? 'ol' : 'ul';
    out.push(`<${tag}>${buf.join('')}</${tag}>`);
    buf = [];
    listType = null;
  };
  for (const block of blocks) {
    if (!block || block._type !== 'block') { flush(); continue; }
    const children = Array.isArray(block.children) ? block.children : [];
    const html = renderChildren(children);
    if (block.listItem) {
      if (listType && listType !== block.listItem) flush();
      listType = block.listItem;
      buf.push(`<li>${html}</li>`);
      continue;
    }
    flush();
    const style = block.style || 'normal';
    if (style === 'h2') out.push(`<h2>${html}</h2>`);
    else if (style === 'h3') out.push(`<h3>${html}</h3>`);
    else if (style === 'blockquote') out.push(`<blockquote>${html}</blockquote>`);
    else out.push(`<p>${html}</p>`);
  }
  flush();
  return out.join('');
}

const formatDate = (d: string | undefined | null) => {
  if (!d) return '';
  const date = new Date(d);
  return Number.isNaN(date.getTime())
    ? ''
    : date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
};

const publishDate = formatDate(post.publishDate);
const heroImage = post.heroImage ? urlFor(post.heroImage).width(1400).format('webp').url() : undefined;
const author = post.author || 'Barbara Kohler';
const tags = post.tags || [];
const bodyHtml = renderPortableText(post.body);
const origin = (Astro.site && Astro.site.toString().replace(/\/$/, '')) || 'https://www.barbarakohlerseminars.com';
const postUrl = `${origin}/blog/${post.slug.current}`;
---
<Layout
  title={post.seoTitle || `${post.title} | Barbara Kohler Seminars`}
  description={post.seoDescription || post.excerpt || 'Read this article from Barbara Kohler Seminars.'}
  ogImage={heroImage}
>
  <Fragment slot="head">
    <meta property="og:type" content="article" />
    <meta property="article:author" content={author} />
    {post.publishDate && <meta property="article:published_time" content={post.publishDate} />}
    {tags.length > 0 && <meta property="article:section" content={tags[0]} />}
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: post.title,
      description: post.excerpt || post.title,
      image: heroImage,
      author: { '@type': 'Person', name: author },
      publisher: { '@type': 'Organization', name: 'Barbara Kohler Seminars, PLLC', url: origin },
      url: postUrl,
      datePublished: post.publishDate,
    })} />
  </Fragment>

  <article class="post">
    {heroImage && (
      <div class="post-hero"><img src={heroImage} alt={post.heroImage?.alt || post.title} width="1400" height="700" /></div>
    )}
    <div class="wrap post-wrap">
      <a class="post-back" href="/blog">&larr; Back to Blog</a>
      <h1 class="post-title">{post.title}</h1>
      {post.excerpt && <p class="post-excerpt">{post.excerpt}</p>}
      <div class="post-meta">
        <span>By <strong>{author}</strong></span>
        {publishDate && <><span>&middot;</span><span>{publishDate}</span></>}
      </div>
      {tags.length > 0 && (
        <div class="post-tags">
          {tags.map((t: string) => <a href={`/blog?tag=${encodeURIComponent(t)}`}>{t}</a>)}
        </div>
      )}
      <div class="post-body" set:html={bodyHtml} />
      <ShareBar title={post.title} url={postUrl} />
    </div>
    <RelatedPosts currentSlug={post.slug.current} currentTags={tags} />
  </article>

  <style is:global>
    .post-hero{width:100%;max-height:520px;overflow:hidden}
    .post-hero img{width:100%;height:100%;object-fit:cover;display:block}
    .post-wrap{max-width:760px;padding-top:44px;padding-bottom:24px}
    .post-back{display:inline-block;font-family:var(--sans);font-size:12px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--sapphire);text-decoration:none;margin-bottom:22px}
    .post-back:hover{color:var(--sapphire-deep)}
    .post-title{font-size:clamp(30px,4.4vw,46px);line-height:1.14;color:var(--navy-ink);letter-spacing:-.01em}
    .post-excerpt{font-size:19px;color:var(--ink-soft);margin-top:14px}
    .post-meta{display:flex;align-items:center;gap:10px;margin-top:16px;padding-bottom:22px;border-bottom:1px solid var(--rule);font-family:var(--sans);font-size:14px;color:var(--ink-soft)}
    .post-meta strong{color:var(--sapphire)}
    .post-tags{display:flex;flex-wrap:wrap;gap:8px;margin:20px 0 4px}
    .post-tags a{font-family:var(--sans);font-size:11.5px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--sapphire);background:rgba(23,56,98,.08);border-radius:999px;padding:6px 12px;text-decoration:none}
    .post-tags a:hover{background:var(--sapphire);color:#fff}
    .post-body{margin-top:30px;font-size:18px;line-height:1.75;color:var(--ink)}
    .post-body p{margin:0 0 20px}
    .post-body h2{font-size:26px;color:var(--navy-ink);margin:38px 0 14px;line-height:1.2}
    .post-body h3{font-size:21px;color:var(--navy-ink);margin:30px 0 10px}
    .post-body a{color:var(--sapphire);text-decoration:underline}
    .post-body ul,.post-body ol{margin:0 0 20px;padding-left:24px}
    .post-body li{margin:0 0 10px}
    .post-body blockquote{margin:26px 0;padding:14px 22px;border-left:3px solid var(--gold);background:var(--paper-soft);font-style:italic;color:var(--ink-soft)}
  </style>
</Layout>
