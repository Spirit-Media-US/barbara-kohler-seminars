---
interface Props {
  title: string;
  url: string;
}
const { title, url } = Astro.props;
const enc = encodeURIComponent;
const fb = `https://www.facebook.com/sharer/sharer.php?u=${enc(url)}`;
const x = `https://twitter.com/intent/tweet?url=${enc(url)}&text=${enc(title)}`;
const em = `mailto:?subject=${enc(title)}&body=${enc(url)}`;
---
<div class="sharebar">
  <span class="sharebar-label">Share</span>
  <a href={fb} target="_blank" rel="noopener noreferrer" aria-label="Share on Facebook">Facebook</a>
  <a href={x} target="_blank" rel="noopener noreferrer" aria-label="Share on X">X</a>
  <a href={em} aria-label="Share by email">Email</a>
</div>
<style>
  .sharebar{display:flex;align-items:center;gap:12px;margin:36px 0 8px;padding-top:22px;border-top:1px solid var(--rule);font-family:var(--sans)}
  .sharebar-label{font-size:12px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--ink-soft)}
  .sharebar a{font-size:13px;font-weight:700;color:var(--sapphire);text-decoration:none;border:1px solid var(--rule);border-radius:999px;padding:6px 14px}
  .sharebar a:hover{background:var(--sapphire);color:#fff;border-color:var(--sapphire)}
</style>
