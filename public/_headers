/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=()
  X-Robots-Tag: index, follow
  # Single site-wide CSP. The embedded Sanity Studio (/studio) lives on this same
  # origin and CF Pages enforces multiple CSP headers as an AND, so a looser path-
  # scoped policy for /studio does NOT work. This one policy keeps the marketing site
  # on a named allowlist while permitting the Sanity vendor origins the Studio needs
  # (core.sanity-cdn.com bridge, studio-static.sanity.io fonts, blob: workers, *.sanity.io APIs).
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob: https://www.googletagmanager.com https://www.google-analytics.com https://static.cloudflareinsights.com https://core.sanity-cdn.com https://*.sanity-cdn.com; style-src 'self' 'unsafe-inline'; font-src 'self' data: https://assets.spiritmediapublishing.com https://studio-static.sanity.io; img-src 'self' https: data: blob:; media-src 'self' blob: https://assets.spiritmediapublishing.com; worker-src 'self' blob:; child-src 'self' blob:; connect-src 'self' https://bks-ebook-subscribe.spirit-media-publishing.workers.dev https://www.google-analytics.com https://*.google-analytics.com https://www.googletagmanager.com https://static.cloudflareinsights.com https://cloudflareinsights.com https://*.api.sanity.io wss://*.api.sanity.io https://api.sanity.io https://*.apicdn.sanity.io https://cdn.sanity.io https://*.sanity.io https://core.sanity-cdn.com https://*.sanity-cdn.com https://studio-static.sanity.io; frame-src https://www.youtube.com https://www.youtube-nocookie.com https://player.vimeo.com https://*.sanity.io https://core.sanity-cdn.com; object-src 'none'; base-uri 'self'; form-action 'self' https://*.sanity.io

